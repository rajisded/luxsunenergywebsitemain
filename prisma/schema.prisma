// Prisma schema for Luxsun Energy — Quote submissions stored in Supabase

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model QuoteRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  requirement String
  urgency     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("quote_requests")
}
